# KSE NMT Simulator — environment variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
HOST=0.0.0.0

# Session secret — change to a random string in production!
SESSION_SECRET=change-me-in-production

# Path to SQLite database file
DB_PATH=/var/lib/kse-nmt/exam.db

# Directory for uploaded images and other data
DATA_DIR=/var/lib/kse-nmt/data

# Session DB directory
SESSION_DB_DIR=/var/lib/kse-nmt

# Safe Exam Browser key validation (optional)
# Set to the SEB Config Key from your SEB configuration file
# If not set, SEB check is disabled (any browser can access the exam)
# SEB_KEY=your-seb-config-key-here

# Secure cookies — only enable if running behind HTTPS (not needed for HTTP/IP-only)
# COOKIE_SECURE=true
